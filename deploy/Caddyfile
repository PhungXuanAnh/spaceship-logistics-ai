# Catch-all on :80 — works for IP access AND ACME HTTP challenge.
:80 {
	encode gzip zstd
	@api {
		path /api/* /healthz /readyz
	}
	handle @api {
		reverse_proxy backend:8000
	}
	handle {
		reverse_proxy frontend:3000
	}
}

# Domain block — Caddy auto-provisions Let's Encrypt cert on :443 once DNS A record resolves.
{$DOMAIN} {
	encode gzip zstd
	@api {
		path /api/* /healthz /readyz
	}
	handle @api {
		reverse_proxy backend:8000
	}
	handle {
		reverse_proxy frontend:3000
	}
}
