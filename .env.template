# Application
APP_ENV=local
LOG_LEVEL=INFO

# Database — Postgres in docker, or sqlite fallback for tests
DATABASE_URL=postgresql+psycopg://spaceship:spaceship@postgres:5432/spaceship
# DATABASE_URL=sqlite:///./dev.db

# JWT / Auth
JWT_SECRET=please-change-me-in-prod-32chars-min
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=480

# Demo seed user (created by alembic migration)
DEMO_USER_EMAIL=demo@spaceship.test
DEMO_USER_PASSWORD=demo123
DEMO_USER_CLIENT_ID=

# LLM provider chain — primary tries first, falls back to FALLBACK_*, then KeywordRouter
# Supported providers: claude (anthropic-compatible HTTP), gemini, keyword
LLM_PROVIDER=keyword
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

FALLBACK_PROVIDER=keyword
FALLBACK_MODEL=
FALLBACK_API_KEY=
FALLBACK_BASE_URL=

# Optional: local Copilot proxy for dev (Anthropic-compatible)
# LLM_PROVIDER=claude
# LLM_MODEL=claude-sonnet-4.6
# LLM_BASE_URL=http://127.0.0.1:8080
# LLM_API_KEY=not-required-for-local-proxy

# Optional: Gemini direct
# FALLBACK_PROVIDER=gemini
# FALLBACK_MODEL=gemini-3.1-pro-preview
# FALLBACK_API_KEY=

# CORS — comma-separated origins for the FE
CORS_ORIGINS=http://localhost:3000

# Frontend (read by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000

# AWS (Phase 8 deploy only)
AWS_REGION=ap-southeast-1
AWS_PROFILE=alexander.xuananh
DOMAIN_NAME=spaceship.xuananh1.site
